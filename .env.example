# Copy to .env and fill in. Never commit .env.

# Local OpenAI-compatible endpoint for Ollama-served models (gpt-oss:20b, etc.).
OLLAMA_BASE_URL=http://localhost:11434/v1

# A model can also be served by a llama.cpp server on another port; point the
# arm at it with an explicit baseUrl (e.g. http://127.0.0.1:8080/v1). No keys
# are needed: everything runs locally.
